NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=cole_sua_publishable_key_aqui

# Pegue no Supabase Dashboard > Project Settings > API.
# Nunca coloque esta chave em componente React ou arquivo enviado ao navegador.
SUPABASE_SERVICE_ROLE_KEY=cole_sua_service_role_key_aqui

# Pegue na conta/app do Mercado Pago.
MERCADO_PAGO_ACCESS_TOKEN=cole_seu_access_token_aqui
MERCADO_PAGO_DEFAULT_PAYER_EMAIL=comprador@premiapix.app

# Use a URL publica do deploy em producao.
MERCADO_PAGO_WEBHOOK_URL=https://seu-dominio.com/api/webhooks/mercado-pago

# Opcional, mas recomendado em producao. Pegue em Mercado Pago > Sua integracao > Webhooks.
MERCADO_PAGO_WEBHOOK_SECRET=cole_o_segredo_do_webhook_aqui
